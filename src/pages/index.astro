---
import Layout from '../layouts/Layout.astro'
import DynamicTitle from '../components/DynamicTitle.vue'
---

<Layout>
	<h1>动态打字机测试</h1>
	<p>
	  Make famdom reignite with
	  <br />
	  <span class="dynamic-title"><DynamicTitle client:idle /></span>
	  <span class="cursor">_</span>
	  <br />
	  in our hands
	</p>
</Layout>

<style>
@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

.cursor {
  animation: blink 1s infinite;
}

.dynamic-title {
  font-size: 1.2rem;
}
</style>
